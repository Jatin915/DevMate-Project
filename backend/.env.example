# MongoDB connection string (MongoDB Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/devmate

# Auth
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# CORS: set to your frontend origin in production, e.g. http://localhost:5173
# Leave unset during dev to allow any origin (reflects request origin).
CLIENT_ORIGIN=http://localhost:5173

# Optional: YouTube Data API v3 key — used to import playlist items when adding a playlist
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# Optional OpenAI evaluator for onboarding assessment
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenRouter for AI code evaluation
OPENROUTER_API_KEY=
# Optional model override (see OpenRouter docs)
# OPENROUTER_MODEL=
